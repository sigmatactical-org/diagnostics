import { ListView } from "std-widgets.slint";
import { SigmaTheme } from "theme.slint";
import { ToolbarButton, Cell, HeaderCell, TableHeader, TableRow, EmptyState } from "widgets/common.slint";

export struct SettingRow {
    key: string,
    value: string,
    read-only: bool,
}

export component SettingsTab inherits Rectangle {
    callback refresh-settings();
    in property <bool> connected: false;
    in property <string> status-text: "";
    in property <[SettingRow]> settings;

    background: SigmaTheme.background;

    VerticalLayout {
        padding: 12px;
        spacing: 10px;
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: "Settings";
                color: SigmaTheme.text;
                font-weight: 700;
                vertical-alignment: center;
            }
            ToolbarButton {
                label: "Refresh";
                clicked => { root.refresh-settings(); }
            }
            Rectangle { horizontal-stretch: 1; }
        }
        Text {
            text: root.status-text;
            color: SigmaTheme.text-dim;
            wrap: word-wrap;
            font-size: SigmaTheme.font-size-small;
        }
        Rectangle {
            vertical-stretch: 1;
            background: SigmaTheme.surface;
            border-radius: 4px;
            border-width: 1px;
            border-color: SigmaTheme.border;

            if root.settings.length == 0: EmptyState {
                message: root.connected ? "No settings received" : "Not connected";
                hint: root.connected
                    ? "Press Refresh to request vehicle settings."
                    : "Connect to the vehicle from the Connect tab, then Refresh.";
            }

            if root.settings.length > 0: VerticalLayout {
                padding: 4px;
                spacing: 4px;
                TableHeader {
                    HeaderCell { text: "Setting"; width: 180px; }
                    HeaderCell { text: "Value"; horizontal-stretch: 1; }
                    HeaderCell { text: "Access"; width: 72px; }
                }
                ListView {
                    for row in root.settings: TableRow {
                        hoverable: false;
                        Cell { text: row.key; width: 180px; color: SigmaTheme.accent; }
                        Cell { text: row.value; horizontal-stretch: 1; }
                        Cell {
                            text: row.read-only ? "read-only" : "writable";
                            width: 72px;
                            color: row.read-only ? SigmaTheme.text-dim : SigmaTheme.accent-green;
                        }
                    }
                }
            }
        }
    }
}
