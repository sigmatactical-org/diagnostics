import { ListView, LineEdit } from "std-widgets.slint";
import { SigmaTheme } from "../theme.slint";
import { FrameRow, SignalRow, ToolbarButton, Cell, HeaderCell, TableHeader, TableRow, EmptyState } from "../widgets/common.slint";

export component Mdf4Tab inherits Rectangle {
    callback export-mdf4();
    callback open-mdf4();
    callback apply-filters();
    callback clear-filters();
    callback frame-selected(int);

    // Mechanic gates these on; can-viewer keeps its defaults (header opens files, plain "Export").
    in property <bool> show-open-mdf4: false;
    in property <string> export-label: "Export";

    in-out property <string> mdf4-path: "";
    in-out property <string> frame-count: "Loaded 0 / 0 frames";
    in-out property <[FrameRow]> frames;
    in-out property <[SignalRow]> signals;
    in-out property <string> filter-can-id: "";
    in-out property <string> filter-message: "";
    in-out property <string> filter-data: "";
    in-out property <int> selected-frame-index: -1;

    background: SigmaTheme.background;

    VerticalLayout {
        padding: 8px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 8px;
            if root.show-open-mdf4: ToolbarButton {
                label: "Open MDF4…";
                clicked => { root.open-mdf4(); }
            }
            ToolbarButton {
                label: root.export-label;
                enabled: root.frames.length > 0;
                clicked => { root.export-mdf4(); }
            }
            Rectangle { horizontal-stretch: 1; }
            Text { text: root.frame-count; color: SigmaTheme.text-dim; vertical-alignment: center; }
        }

        HorizontalLayout {
            spacing: 8px;
            vertical-stretch: 1;

            Rectangle {
                horizontal-stretch: 3;
                background: SigmaTheme.surface;
                border-radius: 4px;
                border-width: 1px;
                border-color: SigmaTheme.border;

                if root.frames.length == 0: EmptyState {
                    message: "No MDF4 file loaded";
                    hint: "Open a log with the MDF4 button in the header, or pass --mdf4 on the command line.";
                }

                if root.frames.length > 0: VerticalLayout {
                    padding: 4px;
                    TableHeader {
                        HeaderCell { text: "#"; width: 40px; }
                        HeaderCell { text: "Timestamp"; width: 100px; }
                        HeaderCell { text: "CAN ID"; width: 80px; }
                        HeaderCell { text: "Ch"; width: 30px; }
                        HeaderCell { text: "DLC"; width: 30px; }
                        HeaderCell { text: "Data"; horizontal-stretch: 1; }
                        HeaderCell { text: "Message"; width: 120px; }
                    }
                    ListView {
                        for row[i] in root.frames: TableRow {
                            selected: i == root.selected-frame-index;
                            clicked => { root.frame-selected(i); }
                            Cell { text: row.index; width: 40px; }
                            Cell { text: row.timestamp; width: 100px; }
                            Cell { text: row.can-id; width: 80px; color: SigmaTheme.accent-amber; }
                            Cell { text: row.channel; width: 30px; color: SigmaTheme.text-dim; }
                            Cell { text: row.dlc; width: 30px; color: SigmaTheme.text-dim; }
                            Cell { text: row.data-hex; horizontal-stretch: 1; }
                            Cell { text: row.message-name; width: 120px; color: SigmaTheme.accent-green; }
                        }
                    }
                }
            }

            VerticalLayout {
                horizontal-stretch: 1;
                min-width: 240px;
                spacing: 8px;

                Rectangle {
                    background: SigmaTheme.surface;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: SigmaTheme.border;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 8px;
                        Text { text: "Filters"; color: SigmaTheme.text; font-weight: 600; }
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: "CAN ID"; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; }
                            LineEdit {
                                min-height: 28px;
                                text <=> root.filter-can-id;
                                placeholder-text: "e.g. 0x123 or comma-separated";
                                accepted => { root.apply-filters(); }
                            }
                        }
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: "Message"; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; }
                            LineEdit {
                                min-height: 28px;
                                text <=> root.filter-message;
                                placeholder-text: "Message name";
                                accepted => { root.apply-filters(); }
                            }
                        }
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: "Data (hex)"; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; }
                            LineEdit {
                                min-height: 28px;
                                text <=> root.filter-data;
                                placeholder-text: "Data hex filter";
                                accepted => { root.apply-filters(); }
                            }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            ToolbarButton { label: "Apply"; clicked => { root.apply-filters(); } }
                            ToolbarButton { label: "Clear"; clicked => { root.clear-filters(); } }
                        }
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                    background: SigmaTheme.surface;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: SigmaTheme.border;
                    VerticalLayout {
                        padding: 4px;
                        spacing: 4px;
                        HorizontalLayout {
                            padding: 4px;
                            Text { text: "Signals"; color: SigmaTheme.text; font-weight: 600; }
                        }

                        if root.signals.length == 0: EmptyState {
                            vertical-stretch: 1;
                            message: root.frames.length == 0
                                ? "Decoded signals appear here"
                                : "Select a frame to decode its signals";
                            hint: root.frames.length == 0
                                ? ""
                                : "Frames decode only when a DBC is loaded.";
                        }

                        if root.signals.length > 0: VerticalLayout {
                            vertical-stretch: 1;
                            TableHeader {
                                HeaderCell { text: "Signal"; width: 100px; }
                                HeaderCell { text: "Value"; width: 80px; }
                                HeaderCell { text: "Unit"; width: 40px; }
                                HeaderCell { text: "Raw"; width: 60px; }
                                HeaderCell { text: "Description"; horizontal-stretch: 1; }
                            }
                            ListView {
                                for sig in root.signals: TableRow {
                                    hoverable: false;
                                    Cell { text: sig.signal-name; width: 100px; color: SigmaTheme.accent; }
                                    Cell { text: sig.value; width: 80px; }
                                    Cell { text: sig.unit; width: 40px; color: SigmaTheme.text-dim; }
                                    Cell { text: sig.raw-value; width: 60px; color: SigmaTheme.text-dim; }
                                    Cell { text: sig.description; horizontal-stretch: 1; color: SigmaTheme.text-dim; }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
