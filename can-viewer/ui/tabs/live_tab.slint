import { ListView, ComboBox } from "std-widgets.slint";
import { SigmaTheme } from "../theme.slint";
import { LiveMessageRow, LiveSignalRow, LiveFrameRow, LiveErrorRow, ToolbarButton, StatusChip, Cell, HeaderCell, TableHeader, TableRow, EmptyState } from "../widgets/common.slint";

export component LiveTab inherits Rectangle {
    callback refresh-interfaces();
    callback start-capture();
    callback stop-capture();
    callback export-capture();
    callback replay-session();
    callback stop-replay();

    // Mechanic gates telemetry-session replay on; can-viewer leaves it off.
    in property <bool> show-replay: false;
    in property <bool> replay-active: false;

    in-out property <[string]> interfaces;
    in-out property <int> selected-interface: 0;
    in-out property <bool> capturing: false;
    in-out property <string> capture-status: "Stopped";
    in-out property <string> stats-text: "";
    in-out property <[LiveMessageRow]> messages;
    in-out property <[LiveSignalRow]> signals;
    in-out property <[LiveFrameRow]> frames;
    in-out property <[LiveErrorRow]> errors;
    // 0 = Messages (+ related signals), 1 = Frames, 2 = Errors
    in-out property <int> live-view: 0;
    // Master-detail: selected message-name filters the signals pane ("" = all).
    property <string> selected-live-message: "";

    background: SigmaTheme.background;

    VerticalLayout {
        padding: 8px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 8px;
            ComboBox {
                model: root.interfaces;
                current-index <=> root.selected-interface;
                min-width: 160px;
            }
            ToolbarButton { label: "Refresh"; clicked => { root.refresh-interfaces(); } }
            if !root.capturing: ToolbarButton { label: "Start"; clicked => { root.start-capture(); } }
            if root.capturing: ToolbarButton { label: "Stop"; clicked => { root.stop-capture(); } }
            ToolbarButton {
                label: "Export MDF4";
                enabled: root.frames.length > 0 || root.messages.length > 0;
                clicked => { root.export-capture(); }
            }
            StatusChip {
                label: "Status";
                value: root.capture-status;
                value-color: root.capturing ? SigmaTheme.accent-green : SigmaTheme.text-dim;
            }
            if root.show-replay: ToolbarButton {
                label: "Replay session…";
                enabled: !root.replay-active;
                clicked => { root.replay-session(); }
            }
            if root.show-replay: ToolbarButton {
                label: "Stop replay";
                enabled: root.replay-active;
                clicked => { root.stop-replay(); }
            }
            Rectangle { horizontal-stretch: 1; }
            Text { text: root.stats-text; color: SigmaTheme.text-dim; vertical-alignment: center; }
        }

        HorizontalLayout {
            spacing: 4px;
            ToolbarButton { label: "Messages"; selected: root.live-view == 0; clicked => { root.live-view = 0; } }
            ToolbarButton { label: "Frames"; selected: root.live-view == 1; clicked => { root.live-view = 1; } }
            ToolbarButton {
                label: root.errors.length > 0 ? "Errors (" + root.errors.length + ")" : "Errors";
                selected: root.live-view == 2;
                clicked => { root.live-view = 2; }
            }
        }

        Rectangle {
            vertical-stretch: 1;
            background: SigmaTheme.surface;
            border-radius: 4px;
            border-width: 1px;
            border-color: SigmaTheme.border;

            // 1. Messages and their related signals (click a message to filter).
            if root.live-view == 0 && root.messages.length == 0: EmptyState {
                message: "No traffic yet";
                hint: "Select an interface and press Start to capture live CAN traffic.";
            }
            if root.live-view == 0 && root.messages.length > 0: VerticalLayout {
                width: 100%;
                height: 100%;
                padding: 4px;
                spacing: 4px;

                TableHeader {
                    HeaderCell { text: "CAN ID"; width: 80px; }
                    HeaderCell { text: "Message"; width: 140px; }
                    HeaderCell { text: "Data"; horizontal-stretch: 1; }
                    HeaderCell { text: "Count"; width: 60px; }
                    HeaderCell { text: "Rate"; width: 60px; }
                }
                ListView {
                    vertical-stretch: 1;
                    for row in root.messages: TableRow {
                        selected: row.message-name != "" && root.selected-live-message == row.message-name;
                        clicked => {
                            root.selected-live-message =
                                root.selected-live-message == row.message-name ? "" : row.message-name;
                        }
                        Cell { text: row.can-id; width: 80px; color: SigmaTheme.accent-amber; }
                        Cell { text: row.message-name; width: 140px; color: SigmaTheme.accent-green; }
                        Cell { text: row.data-hex; horizontal-stretch: 1; }
                        Cell { text: row.count; width: 60px; color: SigmaTheme.text-dim; }
                        Cell { text: row.rate; width: 60px; color: SigmaTheme.text-dim; }
                    }
                }

                Rectangle { height: 1px; background: SigmaTheme.border; }
                Text {
                    text: root.selected-live-message == ""
                        ? "Signals — click a message to filter"
                        : "Signals — " + root.selected-live-message + " (click again to clear)";
                    color: SigmaTheme.text-dim;
                    font-size: SigmaTheme.font-size-small;
                    height: 16px;
                }
                if root.signals.length == 0: EmptyState {
                    vertical-stretch: 1;
                    message: "No decoded signals";
                    hint: "Load a DBC to decode message payloads.";
                }
                if root.signals.length > 0: VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 4px;
                    TableHeader {
                        HeaderCell { text: "Message"; width: 120px; }
                        HeaderCell { text: "Signal"; width: 100px; }
                        HeaderCell { text: "Value"; width: 80px; }
                        HeaderCell { text: "Unit"; width: 40px; }
                        HeaderCell { text: "Min / Max"; horizontal-stretch: 1; }
                    }
                    ListView {
                        for row in root.signals: TableRow {
                            property <bool> shown: root.selected-live-message == "" || row.message-name == root.selected-live-message;
                            hoverable: false;
                            height: self.shown ? SigmaTheme.row-height : 0px;
                            visible: self.shown;
                            Cell { text: row.message-name; width: 120px; color: SigmaTheme.text-dim; }
                            Cell { text: row.signal-name; width: 100px; color: SigmaTheme.accent; }
                            Cell { text: row.value; width: 80px; }
                            Cell { text: row.unit; width: 40px; color: SigmaTheme.text-dim; }
                            Cell { text: row.min-value + " / " + row.max-value; horizontal-stretch: 1; color: SigmaTheme.text-dim; }
                        }
                    }
                }
            }

            // 2. Bare CAN frames.
            if root.live-view == 1 && root.frames.length == 0: EmptyState {
                message: "No frames captured";
                hint: "Select an interface and press Start to capture live CAN traffic.";
            }
            if root.live-view == 1 && root.frames.length > 0: VerticalLayout {
                padding: 4px;
                spacing: 4px;
                TableHeader {
                    HeaderCell { text: "Timestamp"; width: 100px; }
                    HeaderCell { text: "CAN ID"; width: 80px; }
                    HeaderCell { text: "DLC"; width: 30px; }
                    HeaderCell { text: "Data"; horizontal-stretch: 1; }
                    HeaderCell { text: "Flags"; width: 60px; }
                }
                ListView {
                    for row in root.frames: TableRow {
                        hoverable: false;
                        Cell { text: row.timestamp; width: 100px; color: SigmaTheme.text-dim; }
                        Cell { text: row.can-id; width: 80px; color: SigmaTheme.accent-amber; }
                        Cell { text: row.dlc; width: 30px; color: SigmaTheme.text-dim; }
                        Cell { text: row.data-hex; horizontal-stretch: 1; }
                        Cell { text: row.flags; width: 60px; color: SigmaTheme.text-dim; }
                    }
                }
            }

            // 3. Bus errors.
            if root.live-view == 2 && root.errors.length == 0: EmptyState {
                message: "No bus errors";
                hint: "Error frames seen during capture are listed here.";
            }
            if root.live-view == 2 && root.errors.length > 0: VerticalLayout {
                padding: 4px;
                spacing: 4px;
                TableHeader {
                    HeaderCell { text: "Timestamp"; width: 100px; }
                    HeaderCell { text: "Channel"; width: 60px; }
                    HeaderCell { text: "Type"; width: 100px; }
                    HeaderCell { text: "Details"; horizontal-stretch: 1; }
                    HeaderCell { text: "Count"; width: 40px; }
                }
                ListView {
                    for row in root.errors: TableRow {
                        hoverable: false;
                        Cell { text: row.timestamp; width: 100px; color: SigmaTheme.text-dim; }
                        Cell { text: row.channel; width: 60px; color: SigmaTheme.text-dim; }
                        Cell { text: row.error-type; width: 100px; color: SigmaTheme.accent-red; }
                        Cell { text: row.details; horizontal-stretch: 1; }
                        Cell { text: row.count; width: 40px; color: SigmaTheme.text-dim; }
                    }
                }
            }
        }
    }
}
